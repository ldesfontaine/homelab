# {{ ansible_managed }} — DO NOT EDIT MANUALLY
#
# Routes dynamiques chargées par Traefik via le file provider.
# Ces routes s'AJOUTENT à celles que Pangolin sert via son HTTP provider
# (pangolin:3001/api/v1/traefik-config) — pas de conflit tant qu'aucun
# hostname n'est dupliqué.
#
# Middlewares attachés aux routers backend (clé `backend_url`) :
#   - les entrées de `pangolin_default_middlewares` (vide par défaut, levier
#     pour des middlewares génériques sans flag dédié)
#   - + `crowdsec-bouncer` si `pangolin_crowdsec_integration_enabled` est vrai
# Les routers `redirect_to` (apex) ne reçoivent que leur middleware redirect ;
# le filtrage CrowdSec a lieu sur le router cible (308 → backend filtré).

{% set _crowdsec_enabled = pangolin_crowdsec_integration_enabled | default(true) %}
{% set _backend_middlewares = (pangolin_default_middlewares | default([]))
                              + (['crowdsec-bouncer'] if _crowdsec_enabled else []) %}

http:
  routers:
{% for route in pangolin_routes %}
{%   if route.backend_url is defined %}
    {{ route.name }}-router:
      rule: "Host(`{{ route.hostname }}`)"
      service: {{ route.name }}-service
      entryPoints:
        - websecure
{%     if _backend_middlewares | length > 0 %}
      middlewares:
{%       for mw in _backend_middlewares %}
        - {{ mw }}
{%       endfor %}
{%     endif %}
      tls:
        certResolver: {{ pangolin_letsencrypt_resolver_name }}
{%   elif route.redirect_to is defined %}
    {{ route.name }}-router:
      rule: "Host(`{{ route.hostname }}`)"
      service: noop-service
      entryPoints:
        - websecure
      middlewares:
        - {{ route.name }}-redirect
      tls:
        certResolver: {{ pangolin_letsencrypt_resolver_name }}
{%   endif %}
{% endfor %}

  services:
{% for route in pangolin_routes %}
{%   if route.backend_url is defined %}
    {{ route.name }}-service:
      loadBalancer:
        servers:
          - url: "{{ route.backend_url }}"
{%   endif %}
{% endfor %}
    # Service sentinelle pour les routeurs purement redirect (jamais joint).
    noop-service:
      loadBalancer:
        servers:
          - url: "http://127.0.0.1:1"

  middlewares:
{% for route in pangolin_routes %}
{%   if route.redirect_to is defined %}
    {{ route.name }}-redirect:
      redirectRegex:
        regex: "^https?://[^/]+/(.*)"
        replacement: "{{ route.redirect_to }}/$1"
        permanent: {{ route.permanent | default(true) | string | lower }}
{%   endif %}
{% endfor %}
{% if _crowdsec_enabled %}
    # Bouncer CrowdSec — délègue à l'agent (crowdsec:8080 sur pangolin-net)
    # la décision de bloquer une IP. Mode `stream` : le plugin maintient un
    # cache local synchronisé périodiquement, donc pas d'appel LAPI par
    # requête. `updateMaxFailure: 0` = fail-open si l'agent est indisponible
    # (on préfère laisser passer plutôt que casser le site).
    #
    # `forwardedHeadersTrustedIPs` / `clientTrustedIPs` listent les sources
    # autorisées à fournir un header X-Forwarded-For/X-Real-IP — sinon Traefik
    # logue l'IP du dernier hop (loopback ou Docker bridge) et le bouncer
    # banit le réseau Docker au lieu du vrai client.
    crowdsec-bouncer:
      plugin:
        crowdsec-bouncer:
          enabled: true
          logLevel: "INFO"
          crowdsecMode: "stream"
          updateIntervalSeconds: 15
          updateMaxFailure: 0
          defaultDecisionSeconds: 60
          httpTimeoutSeconds: 10
          crowdsecLapiKey: "{{ vault_crowdsec_bouncer_key }}"
          crowdsecLapiHost: "crowdsec:8080"
          crowdsecLapiScheme: "http"
          forwardedHeadersTrustedIPs:
            - "127.0.0.1/32"
            - "172.16.0.0/12"
          clientTrustedIPs:
            - "127.0.0.1/32"
            - "172.16.0.0/12"
{% endif %}
