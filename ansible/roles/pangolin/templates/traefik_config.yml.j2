# {{ ansible_managed }} — DO NOT EDIT MANUALLY
#
# Config statique Traefik. Différences avec l'upstream Pangolin :
#   * cert resolver = cloudflare (DNS-01) au lieu de letsencrypt (HTTP-01)
#   * api.insecure = false (l'API admin n'est pas exposée publiquement)
#   * tout le reste (badger plugin, providers HTTP+file, ping) est conservé
#     car nécessaire au fonctionnement de Pangolin.

api:
  insecure: false
  dashboard: true

providers:
  http:
    # Pangolin sert dynamiquement sa propre config Traefik via cette URL.
    endpoint: "http://pangolin:3001/api/v1/traefik-config"
    pollInterval: "5s"
  file:
    # Routes statiques que nous (Ansible) ajoutons par-dessus celles de Pangolin :
    # portfolio backend + redirection apex (cf. templates/dynamic_config.yml.j2).
    filename: "/etc/traefik/dynamic_config.yml"
    watch: true

experimental:
  plugins:
    badger:
      moduleName: "github.com/fosrl/badger"
      version: "v1.3.1"
{% if pangolin_crowdsec_integration_enabled | default(true) %}
    # Plugin CrowdSec — appliqué aux routers backend via le middleware
    # `crowdsec-bouncer` défini dans dynamic_config.yml (cf. session 5).
    # Le plugin contacte l'agent via DNS Docker (crowdsec:8080) sur pangolin-net.
    crowdsec-bouncer:
      moduleName: "github.com/maxlerebourg/crowdsec-bouncer-traefik-plugin"
      version: "{{ pangolin_traefik_plugin_crowdsec_version }}"
{% endif %}

log:
  level: "INFO"
  format: "common"
  maxSize: 100
  maxBackups: 3
  maxAge: 3
  compress: true

# accessLog en JSON pour que le parser `crowdsecurity/traefik` ingère
# proprement les champs (URL, status, IP réelle via X-Forwarded-For).
# Les headers sensibles (cookies Payload, auth) sont dropés par défaut ;
# on ne garde que ceux utiles à la détection (User-Agent, Referer, IPs).
accessLog:
  filePath: "/var/log/traefik/access.log"
  bufferingSize: 100
  format: json
  fields:
    defaultMode: keep
    headers:
      defaultMode: drop
      names:
        User-Agent: keep
        Referer: keep
        X-Forwarded-For: keep
        X-Real-Ip: keep

certificatesResolvers:
  {{ pangolin_letsencrypt_resolver_name }}:
    acme:
      email: "{{ pangolin_letsencrypt_email }}"
      storage: "/letsencrypt/acme.json"
      caServer: "{{ pangolin_letsencrypt_ca_server }}"
      dnsChallenge:
        provider: cloudflare
        resolvers:
          - "1.1.1.1:53"
          - "1.0.0.1:53"

entryPoints:
  web:
    address: ":80"
    http:
      redirections:
        entryPoint:
          to: websecure
          scheme: https
          permanent: true
  websecure:
    address: ":443"
    transport:
      respondingTimeouts:
        readTimeout: "30m"
    http:
      tls:
        certResolver: "{{ pangolin_letsencrypt_resolver_name }}"
      encodedCharacters:
        allowEncodedSlash: true
        allowEncodedQuestionMark: true

serversTransport:
  insecureSkipVerify: true

ping:
  entryPoint: "web"
