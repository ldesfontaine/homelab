# {{ ansible_managed }} — DO NOT EDIT MANUALLY
#
# Config Pangolin (https://docs.pangolin.net/self-host/advanced/config-file).
# Le sous-ensemble ci-dessous correspond à l'état "session 4" (frontal public
# + 1 domaine géré). Les sessions ultérieures ajouteront des entrées dans
# `domains:` quand on multipliera les services exposés.

app:
  dashboard_url: "{{ pangolin_dashboard_url }}"
  log_level: "info"
  save_logs: false
  log_failed_attempts: true
  telemetry:
    anonymous_usage: false   # pas de télémétrie sortante
  notifications:
    product_updates: false
    new_releases: false

server:
  external_port: 3000
  internal_port: 3001
  next_port: 3002
  integration_port: 3003
  internal_hostname: "pangolin"
  session_cookie_name: "p_session_token"
  resource_access_token_param: "p_token"
  resource_access_token_headers:
    id: "P-Access-Token-Id"
    token: "P-Access-Token"
  resource_session_request_param: "p_session_request"
  secret: "{{ pangolin_server_secret }}"
  trust_proxy: 1
  dashboard_session_length_hours: 720
  resource_session_length_hours: 720
  cors:
    origins:
      - "{{ pangolin_dashboard_url }}"
    methods: ["GET", "POST", "PUT", "DELETE", "PATCH"]
    allowed_headers: ["X-CSRF-Token", "Content-Type"]
    credentials: false

domains:
  primary:
    base_domain: "{{ homelab_domain }}"
    cert_resolver: "{{ pangolin_letsencrypt_resolver_name }}"
    prefer_wildcard_cert: false

# Gerbil — endpoints WG pour les futurs agents Newt côté homelab.
gerbil:
  start_port: {{ pangolin_port_wg_data }}
  clients_start_port: {{ pangolin_port_wg_control }}
  base_endpoint: "{{ homelab_fqdn_pangolin }}"
  subnet_group: "100.89.137.0/20"
  block_size: 24
  site_block_size: 30
  use_subdomain: false

traefik:
  http_entrypoint: "web"
  https_entrypoint: "websecure"
  cert_resolver: "{{ pangolin_letsencrypt_resolver_name }}"
  prefer_wildcard_cert: false
  monitor_interval: 5000
  site_types: ["newt", "wireguard", "local"]
  # On garde file_mode désactivé : Pangolin sert ses propres routes via API,
  # nos routes statiques (portfolio, apex) sont déclarées dans dynamic_config.yml.
  file_mode: false
  pp_transport_prefix: "pp-transport-v"

orgs:
  block_size: 24
  subnet_group: "100.90.128.0/20"
  utility_subnet_group: "100.96.128.0/20"

rate_limits:
  global:
    window_minutes: 1
    max_requests: 100
  auth:
    window_minutes: 1
    max_requests: 10

flags:
  require_email_verification: false
  disable_signup_without_invite: true
  disable_user_create_org: false
  allow_raw_resources: true
  enable_integration_api: false
  disable_local_sites: false
  disable_basic_wireguard_sites: false
  disable_product_help_banners: false
  disable_config_managed_domains: false
  disable_enterprise_features: false
