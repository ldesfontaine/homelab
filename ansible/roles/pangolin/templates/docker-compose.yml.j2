# {{ ansible_managed }}
#
# Pangolin = reverse proxy public du homelab (ADR-001).
# Topologie alignée avec https://docs.pangolin.net/self-host/manual/docker-compose :
#
#   pangolin  : control plane (API + Next.js dashboard) — pas de port host
#   gerbil    : termine les tunnels WG des agents Newt distants. Publie aussi
#               80/443 (Traefik s'y attache via network_mode: service:gerbil).
#   traefik   : reverse proxy effectif, conf statique + DNS-01 Cloudflare.
#
# Seul container du VPS à publier des ports publics (cf. ADR-002).

services:
  pangolin:
    image: {{ pangolin_image }}:{{ pangolin_version }}
    container_name: {{ _pangolin_container_name }}
    restart: unless-stopped
    environment:
      # Seed admin (consommé au premier boot par Pangolin si aucun user
      # n'existe encore — sinon ignoré, ce qui rend la task idempotente).
      ADMIN_EMAIL: ${ADMIN_EMAIL}
      ADMIN_PASSWORD: ${ADMIN_PASSWORD}
    # Pas de `ports:` host : Pangolin est Host-aware (Express middleware
    # qui route en fonction du Host header pour servir login + UI). Un
    # binding "IP:port:port" depuis le tunnel WG renvoie 404 sur "/".
    # L'accès admin actuel passe par SSH tunnel (cf. runbook session 6 §7.2).
    # Cible Phase 11 : exposition publique de pangolin.{{ homelab_domain }}
    # derrière Authentik (OIDC) + reverse proxy interne — alors et seulement
    # alors le dashboard sera atteignable via FQDN sans tunnel.
    volumes:
      - ./config:/app/config
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3001/api/v1/"]
      interval: 10s
      timeout: 10s
      retries: 15

  gerbil:
    image: {{ pangolin_gerbil_image }}:{{ pangolin_gerbil_version }}
    container_name: {{ _pangolin_gerbil_container_name }}
    restart: unless-stopped
    depends_on:
      pangolin:
        condition: service_healthy
    command:
      - --reachableAt=http://gerbil:3004
      - --generateAndSaveKeyTo=/var/config/key
      - --remoteConfig=http://pangolin:3001/api/v1/
    volumes:
      - ./config/:/var/config
    cap_add:
      - NET_ADMIN
      - SYS_MODULE
    ports:
      # WireGuard data plane (agents Newt) — exposés mais bloqués par UFW
      # tant qu'un agent n'est pas activé (cf. tasks/ufw-allow.yml).
      - "{{ pangolin_port_wg_data }}:51820/udp"
      - "{{ pangolin_port_wg_control }}:21820/udp"
      # HTTP/HTTPS publics — autorisés via `ufw route allow` (tasks/ufw-allow.yml).
      - "{{ pangolin_port_https }}:443"
      - "{{ pangolin_port_http }}:80"

  traefik:
    image: {{ pangolin_traefik_image }}:{{ pangolin_traefik_version }}
    container_name: {{ _pangolin_traefik_container_name }}
    restart: unless-stopped
    # Pas de réseau propre : Traefik partage la stack réseau de Gerbil pour
    # que les ports 80/443 publiés par Gerbil arrivent dans Traefik.
    network_mode: service:gerbil
    depends_on:
      pangolin:
        condition: service_healthy
    command:
      - --configFile=/etc/traefik/traefik_config.yml
    environment:
      # Lu par le provider DNS-01 cloudflare de Traefik.
      CF_DNS_API_TOKEN: ${CF_DNS_API_TOKEN}
    volumes:
      - ./config/traefik:/etc/traefik:ro
      - ./config/letsencrypt:/letsencrypt
      - ./config/traefik/logs:/var/log/traefik

networks:
  # Le compose upstream définit `default` avec le nom externe "pangolin".
  # On utilise notre nom canonique {{ pangolin_docker_network }} créé par
  # `prep.yml` (external: true) pour qu'il soit référencable par les autres
  # rôles (portfolio, futurs services backend).
  default:
    external: true
    name: {{ pangolin_docker_network }}
