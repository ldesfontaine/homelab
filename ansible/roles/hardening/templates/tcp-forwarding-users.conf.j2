# Managed by Ansible -- role hardening -- DO NOT EDIT MANUALLY
#
# Exception ciblee a la baseline `AllowTcpForwarding no` posee par
# devsec.hardening.ssh_hardening (drop-in 99-hardening.conf charge avant
# celui-ci). On reouvre AllowTcpForwarding UNIQUEMENT pour les users
# admin listes dans `hardening_ssh_tcp_forwarding_users` (defaults).
#
# Cas d'usage actuel : permettre `ssh -L 3000:127.0.0.1:3000 deploy@vps`
# depuis le laptop pour atteindre le dashboard Pangolin via
# http://localhost:3000. Pangolin route en interne par Host header
# (architecture reverse-proxy upstream), un acces "IP+port direct" via
# le tunnel WG ne suffit donc pas tant qu'Authentik + reverse proxy
# interne ne sont pas en place.
#
# sshd parse les sshd_config.d/*.conf en ordre lexicographique. 99-hardening
# < 99-tcp-forwarding-users : la directive globale est lue en premier (no),
# puis le bloc Match override pour le user matching.

{% for user in hardening_ssh_tcp_forwarding_users %}
Match User {{ user }}
    AllowTcpForwarding yes

{% endfor %}
