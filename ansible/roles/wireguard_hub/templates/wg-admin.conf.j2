## {{ ansible_managed }} -- DO NOT EDIT MANUALLY
##
## Hub WireGuard admin -- acces distant aux interfaces internes du VPS.
## Gere par Ansible (role wireguard_hub). Toute modif manuelle sera ecrasee
## au prochain run.

[Interface]
Address    = {{ wg_admin_hub_address }}
ListenPort = {{ wg_admin_listen_port }}
PrivateKey = {{ _wg_admin_private_key }}

# Forwarding active pour permettre au futur peer OPNsense de router son trafic
# LAN (10.10.x.x) a travers ce hub. Persistance reboot dans
# /etc/sysctl.d/99-wireguard-forward.conf (PostUp ne couvre que les sessions
# ou l'interface monte effectivement).
PostUp     = sysctl -w net.ipv4.ip_forward=1
PostUp     = iptables -A FORWARD -i %i -j ACCEPT
PostUp     = iptables -A FORWARD -o %i -j ACCEPT
PostDown   = iptables -D FORWARD -i %i -j ACCEPT
PostDown   = iptables -D FORWARD -o %i -j ACCEPT

{% for peer in wg_admin_peers %}
[Peer]
# {{ peer.name }}
PublicKey  = {{ peer.pubkey }}
AllowedIPs = {{ peer.allowed_ips }}

{% endfor %}
