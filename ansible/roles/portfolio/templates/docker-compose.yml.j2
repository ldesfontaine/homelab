# {{ ansible_managed }}
#
# Portfolio — déploiement session 3, modifié session 4 (Pangolin).
# - Image pull depuis GHCR (ADR-000 Décision 6, pas de build sur le VPS)
# - Session 3 : binding 127.0.0.1 (testable via SSH tunnel).
# - Session 4 : portfolio_bind_localhost=false par défaut → AUCUN port host
#   publié, le container est joignable uniquement via le réseau Docker
#   partagé `pangolin-net` (Traefik résout `portfolio:3000` via DNS Docker).

services:
  portfolio:
    image: {{ portfolio_image }}:{{ portfolio_image_tag }}
    container_name: {{ _portfolio_container_name }}
    restart: unless-stopped
    read_only: true
    security_opt:
      - no-new-privileges:true
    cap_drop:
      - ALL
    tmpfs:
      - /tmp
      - /app/.next/cache
    environment:
      HOSTNAME: 0.0.0.0
      NODE_ENV: production
      PAYLOAD_SECRET: ${PAYLOAD_SECRET}
      DATABASE_URI: file:/data/payload.db
      SITE_URL: {{ portfolio_site_url }}
      GOATCOUNTER_VHOST: {{ portfolio_goatcounter_vhost }}
{% if portfolio_bind_localhost %}
    ports:
      # Override de debug / rollback : binding 127.0.0.1 — non exposé sur
      # internet (cf. ADR-002). En conf nominale session 4 ce bloc DISPARAÎT.
      - "127.0.0.1:{{ portfolio_container_port }}:{{ portfolio_container_port }}"
{% endif %}
    volumes:
      - {{ portfolio_data_volume }}:/data
      - {{ portfolio_media_volume }}:/app/media
    networks:
{% for net in portfolio_docker_networks %}
      - {{ net }}
{% endfor %}
    healthcheck:
      test: ["CMD", "wget", "-qO-", "http://127.0.0.1:{{ portfolio_container_port }}/"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s

volumes:
  {{ portfolio_data_volume }}:
  {{ portfolio_media_volume }}:

networks:
{% for net in portfolio_docker_networks %}
  {{ net }}:
    external: true
{% endfor %}
