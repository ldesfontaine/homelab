# {{ ansible_managed }} — DO NOT EDIT MANUALLY
#
# Politique d'escalation CrowdSec — UNIQUEMENT des bans (pas de captcha,
# décision projet session 5). Les filtres sont évalués séquentiellement,
# premier match gagne (`on_success: break`).

---
name: ban_critical
debug: false
filters:
  - "Alert.GetScenario() in ['crowdsecurity/http-cve', 'crowdsecurity/http-bf']"
decisions:
  - type: ban
    duration: {{ crowdsec_ban_critical_hours }}h
on_success: break

---
name: ban_high
debug: false
filters:
  - "Alert.GetScenario() in ['crowdsecurity/http-probing', 'crowdsecurity/http-sensitive-files']"
decisions:
  - type: ban
    duration: {{ crowdsec_ban_high_hours }}h
on_success: break

---
name: ban_medium
debug: false
filters:
  - "Alert.GetScenario() == 'crowdsecurity/http-crawl-non_statics'"
decisions:
  - type: ban
    duration: {{ crowdsec_ban_medium_hours }}h
on_success: break

---
# Fallback : tout signal restant à remédiation active reçoit un ban high.
# Couvre notamment les scénarios sshd et les futurs scénarios ajoutés.
name: default_ban
debug: false
filters:
  - "Alert.Remediation == true"
decisions:
  - type: ban
    duration: {{ crowdsec_ban_high_hours }}h
on_success: break
