# {{ ansible_managed }}
#
# Agent CrowdSec — déployé sur `{{ crowdsec_docker_network }}` (créé par le
# rôle pangolin). Aucun port host publié : la LAPI :8080 est joignable
# uniquement depuis Traefik via le DNS Docker `crowdsec`. Conforme ADR-002
# (Pangolin/Traefik est l'unique frontal HTTP du VPS).

services:
  crowdsec:
    image: "{{ crowdsec_image }}:{{ crowdsec_image_tag }}"
    container_name: {{ _crowdsec_container_name }}
    restart: unless-stopped
    environment:
      # Collections / scenarios hub à installer au boot (idempotent côté image).
      COLLECTIONS: "{{ crowdsec_collections | join(' ') }}"
      # Tant qu'on n'est pas enrôlé sur la Console, on coupe CAPI pour ne pas
      # logger des erreurs de polling. Activé automatiquement dès qu'une
      # `vault_crowdsec_enroll_key` est posée.
      DISABLE_ONLINE_API: "{{ 'false' if (crowdsec_enroll_key | length > 0) else 'true' }}"
      # Niveau de log de l'agent — info en routine, debug si besoin de creuser.
      LEVEL_INFO: "true"
    volumes:
      - "{{ crowdsec_config_dir }}:/etc/crowdsec"
      - "{{ crowdsec_data_dir }}:/var/lib/crowdsec/data"
      # Logs Traefik en lecture seule — parser `crowdsecurity/traefik` (JSON).
      - "{{ crowdsec_traefik_logs_host_path }}:/var/log/traefik:ro"
      # Auth log host pour scénarios sshd — RO.
      - "{{ crowdsec_auth_log_host_path }}:/var/log/auth.log:ro"
    security_opt:
      - "no-new-privileges:true"
    cap_drop:
      - ALL
    # DAC_READ_SEARCH suffit pour traverser /var/log/* (root:adm 640 sur Debian)
    # sans accorder DAC_OVERRIDE complet — principe de moindre privilège.
    cap_add:
      - DAC_READ_SEARCH
    healthcheck:
      test: ["CMD", "cscli", "version"]
      interval: 30s
      timeout: 5s
      retries: 3
      start_period: 30s
    networks:
      - {{ crowdsec_docker_network }}

networks:
  {{ crowdsec_docker_network }}:
    name: {{ crowdsec_docker_network }}
    external: true
