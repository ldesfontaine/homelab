# {{ ansible_managed }}
#
# Configuration chrony — rôle common (homelab)
# Concept critique 14.7 du cahier : sync horaire stricte (OIDC, certs, logs).

{% for server in common_chrony_servers %}
server {{ server }}
{% endfor %}

# Driftfile standard Debian
driftfile /var/lib/chrony/chrony.drift

# Keys file (auth NTP par clés partagées — conservé pour compat, non utilisé)
keyfile /etc/chrony/chrony.keys

# Step la clock si la dérive dépasse 1s pendant les 3 premières mises à jour
makestep 1.0 3

# Synchronise la RTC du kernel avec l'horloge système (utile au reboot)
rtcsync

# Volume de logs raisonnable
logdir /var/log/chrony

# Le VPS n'est pas un serveur NTP — pas d'allow (deny par défaut implicite)
